# ──────────────────────────────────────────────────────────────
# Dream Reflector – Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit your real .env file to version control.

# Required: Your Google Gemini API key.
# Get one at https://aistudio.google.com/apikey
# When deploying to Vercel, add this in the Vercel dashboard under
# Project → Settings → Environment Variables.
GEMINI_API_KEY="your-gemini-api-key-here"

# Optional: Override the app URL (used for OAuth callbacks, self-links, etc.)
APP_URL="https://your-vercel-deployment-url.vercel.app"
